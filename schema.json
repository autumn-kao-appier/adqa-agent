{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ADQA Knowledge Case",
  "description": "Schema for distilled ADQA investigation cases. Source of truth for brew and ask skills.",

  "required_fields": [
    "pattern_id",
    "knowledge_type",
    "symptom.signature",
    "symptom.funnel_stage",
    "root_cause.summary",
    "root_cause.confidence",
    "status",
    "provenance.thread_refs",
    "provenance.as_of"
  ],

  "best_effort_fields": [
    "symptom.scope_tags.ssp",
    "symptom.observable_signals",
    "symptom.metric",
    "root_cause.category",
    "root_cause.mechanism",
    "resolution.fix",
    "resolution.verified_by",
    "recurrence.count",
    "provenance.confluence.status",
    "last_mentioned"
  ],

  "example": {
    "pattern_id": "qa-crossx-newcomer-bid-algorix-companion-filter-a3f9c1",

    "symptom": {
      "signature": "Algorix 第一方流量全部 no bid",
      "funnel_stage": ["Bid"],
      "pipeline_layer": "L6 SSP SDK",
      "metric": "bid_rate",
      "observable_signals": [
        "imp_join_all2 有 request，無 win",
        "diagnose_v2 顯示 companion_type filter"
      ],
      "scope_tags": {
        "ssp": ["Algorix"],
        "os": ["AOS"],
        "region": [],
        "dc": []
      }
    },

    "root_cause": {
      "summary": "Algorix 第一方 bid request companion_types 為空，VAST Video 全被 filter",
      "category": "upstream-ssp",
      "confidence": "confirmed",
      "linked_change": { "type": "ssp-behavior", "ref": "" }
    },

    "resolution": {
      "fix": "改用 Dynamic Video 取代 VAST Video 在 Algorix 第一方流量",
      "verified_by": "切換後有 win/show",
      "note": null,
      "ttr_minutes": null
    },

    "status": "resolved",
    "has_workaround": false,

    "recurrence": {
      "count": 1,
      "first_seen": "2025-11",
      "last_seen": "2025-11"
    },

    "last_mentioned": "2025-11",

    "related_cases": [],

    "notes": null,

    "provenance": {
      "source": "jira",
      "thread_refs": [
        "https://appier.atlassian.net/browse/ADQA-1664",
        "https://appier.slack.com/archives/C02UBHUKBPW/p1779247742021589"
      ],
      "confluence": {
        "status": "silent",
        "urls": []
      },
      "as_of": "2025-11-18",
      "distilled_by": "brew-skill@v1"
    },

    "volatile": {
      "specific_values": ["companion_types: []", "bid_rate 0%"],
      "ticket_ids": ["ADQA-1664"],
      "dates": ["2025-11-13"]
    }
  },

  "field_definitions": {
    "pattern_id": {
      "format": "{channel_slug}-{funnel_stage_lower}-{domain_slug}-{hash6}",
      "hash_source": "primary source ID (Jira key or Slack thread_ts)",
      "example": "qa-crossx-newcomer-bid-algorix-companion-filter-a3f9c1"
    },
    "related_cases": {
      "type": "array of objects",
      "format": "[{\"key\": \"ADQA-XXXX\", \"url\": \"https://appier.atlassian.net/browse/ADQA-XXXX\"}]",
      "note": "只收錄 Jira issuelinks 中明確設定的關聯票。key + url 都存，直接拿就有連結。"
    },
    "funnel_stage": {
      "type": "array",
      "values": ["Traffic", "Bid", "Win-Show", "Click", "Action"],
      "note": "Array. First element is root stage. Downstream affected stages follow.",
      "edge_cases": {
        "setup_config": "Use Traffic",
        "multi_ssp_comparison": "Single case, differences in volatile.specific_values"
      }
    },
    "confidence": {
      "values": ["confirmed", "likely", "unverified"],
      "note": "Use highest confirmed value when multiple SSPs have different confidence"
    },
    "status": {
      "values": ["resolved", "recurring", "known-degradation", "by-design", "wontfix"],
      "workaround": "resolved + has_workaround: true",
      "by_design": "resolution.fix = null, resolution.note = explanation"
    },
    "category": {
      "values": ["config-change", "deploy", "upstream-ssp", "appier-creative", "appier-pipeline", "data-bug", "known-degradation"]
    },
    "mechanism": {
      "values": ["auto-click", "auto-redirect", "traffic-quality", "ssp-server-change", "macro-substitution", "bid-filter", "config-mismatch", "unknown"],
      "note": "What kind of failure, regardless of who owns it. Pairs with category."
    },
    "knowledge_type": {
      "values": ["fact", "behavior", "phenomenon"],
      "note": "知識類型，決定時效衰減方式。fact: 穩定技術事實（encoding 規則、架構限制），超過 6 個月仍維持原始可信度。behavior: SSP/系統行為特徵（auto-click、auto-redirect），超過 6 個月降為低可信。phenomenon: 觀察到的現象/流量模式（暴量、CTR 異常），超過 6 個月降為低可信。任何類型超過 12 個月視為過期，不顯示。"
    },
    "confluence_status": {
      "values": ["aligned", "conflicts", "silent"]
    },
    "source": {
      "values": ["slack", "jira", "jira+slack"]
    }
  }
}
